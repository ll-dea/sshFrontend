<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - EventPlanner</title>

    <!-- Boxicons -->
    <link href="https://unpkg.com/boxicons@2.0.9/css/boxicons.min.css" rel="stylesheet" />

    <!-- Bootstrap -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <!-- Custom CSS -->
    <link rel="stylesheet" href="~/css/user.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/events.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/SSH_FrontEnd.styles.css" asp-append-version="true" />

    <!-- Font Awesome (if needed) -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
</head>
<body>
    <!-- Main Layout Container -->
    <div class="layout-container">
        <!-- SIDEBAR -->
        <aside id="sidebar">
            <a asp-controller="User" asp-action="Dashboard" class="brand">
                <i class="bx bxs-smile"></i>
                <span class="text">EventPlanner</span>
            </a>
            <ul class="side-menu top">
                <li>
                    <a asp-controller="User" asp-action="Dashboard">
                        <i class="bx bxs-dashboard"></i>
                        <span class="text">Dashboard</span>
                    </a>
                </li>
                <li>
                    <a asp-controller="User" asp-action="Events">
                        <i class="bx bxs-calendar-event"></i>
                        <span class="text">My Events</span>
                    </a>
                </li>
                <li>
                    <a asp-controller="User" asp-action="Bookings">
                        <i class="bx bxs-book-content"></i>
                        <span class="text">My Bookings</span>
                    </a>
                </li>
            </ul>
        </aside>

        <!-- MAIN CONTENT -->
        <div class="main-content">
            <!-- NAVBAR -->
            <nav class="navbar">
                <i class="bx bx-menu toggle-sidebar"></i>
                <div class="navbar-title">
                    @ViewData["NavTitle"]
                </div>
                <div class="navbar-actions">
                    @if (IsSectionDefined("NavbarActions"))
                    {
                    @RenderSection("NavbarActions", required: false)
                    }
                    else
                    {
                    <form asp-controller="User" asp-action="Events" method="get" class="search-form">
                        <div class="form-input">
                            <input type="search" name="searchTerm" placeholder="Search..." />
                            <button type="submit" class="search-btn">
                                <i class="bx bx-search"></i>
                            </button>
                        </div>
                    </form>
                    }
                </div>
            </nav>

            <!-- PAGE CONTENT -->
            <main class="content-wrapper">
                @RenderBody()
            </main>
        </div>
    </div>

    <!-- Footer -->
    <footer class="footer">
        <div class="container">
            &copy; @DateTime.Now.Year - EventPlanner
        </div>
    </footer>

    <!-- Scripts -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/user.js" asp-append-version="true"></script>

    <!-- Global Scripts -->
    <script>
        // Toggle sidebar
        document.querySelector('.toggle-sidebar').addEventListener('click', function () {
            document.getElementById('sidebar').classList.toggle('collapsed');
            document.querySelector('.main-content').classList.toggle('expanded');
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
