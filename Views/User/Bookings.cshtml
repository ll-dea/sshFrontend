@{
    Layout = "_Layout";
}
<link rel="stylesheet" href="~/css/user.css" />
<!--<script src="~/js/user.js"></script>-->
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- Boxicons -->
    <link href="https://unpkg.com/boxicons@2.0.9/css/boxicons.min.css" rel="stylesheet" />

    <title>My Bookings - EventPlanner</title>
</head>
<body>
    <!-- SIDEBAR -->
    <section id="sidebar">
        <a href="/user/dashboard" class="brand">
            <i class="bx bxs-smile"></i>
            <span class="text">EventPlanner</span>
        </a>
        <ul class="side-menu top">
            <li class="active">
                <a href="/user/dashboard"><i class="bx bxs-dashboard"></i><span class="text">Dashboard</span></a>
            </li>
            <li>
                <a href="/user/events"><i class="bx bxs-calendar-event"></i><span class="text">My Events</span></a>
            </li>
            <li>
                <a href="/user/bookings"><i class="bx bxs-book-content"></i><span class="text">My Bookings</span></a>
            </li>
        </ul>
        <ul class="side-menu">
            <li>
                <a href="#" class="logout">
                    <i class="bx bxs-log-out-circle"></i>
                    <span class="text">Logout</span>
                </a>
            </li>
        </ul>
    </section>
    <!-- SIDEBAR -->
    <!-- CONTENT -->
    <section id="content">
        <!-- NAVBAR -->
        <nav>
            <i class="bx bx-menu"></i>
            <a href="#" class="nav-link">My Bookings</a>
            <form action="#">
                <div class="form-input">
                    <input type="search" placeholder="Search bookings..." />
                    <button type="submit" class="search-btn">
                        <i class="bx bx-search"></i>
                    </button>
                </div>
            </form>
            <input type="checkbox" id="switch-mode" hidden />
            <label for="switch-mode" class="switch-mode"></label>
        </nav>
        <!-- NAVBAR -->
        <!-- MAIN -->
        <main>
            <div class="head-title">
                <div class="left">
                    <h1>My Bookings</h1>
                    <ul class="breadcrumb">
                        <li>
                            <a asp-controller="User" asp-action="dashboard"></a>
                        </li>
                        <li><i class="bx bx-chevron-right"></i></li>
                        <li>
                            <a class="active" href="#">My Bookings</a>
                        </li>
                    </ul>
                </div>
            </div>

            <div class="bookings-container">
                <!-- Booking Card 1 -->
                <div class="booking-card">
                    <div class="booking-header">
                        <h3>Divine Florist</h3>
                        <span class="category">Florist</span>
                    </div>
                    <p><strong>Booked On:</strong> April 16, 2025</p>
                    <p><strong>Status:</strong> <span class="status pending">Pending</span></p>
                    <div class="booking-actions">
                        <button class="btn-view"><i class="bx bx-show"></i> View</button>
                        <button class="btn-edit"><i class="bx bx-x"></i> Cancel</button>
                    </div>
                </div>

                <!-- Booking Card 2 -->
                <div class="booking-card">
                    <div class="booking-header">
                        <h3>Sweet Cravings</h3>
                        <span class="category">Pastry</span>
                    </div>
                    <p><strong>Booked On:</strong> April 15, 2025</p>
                    <p><strong>Status:</strong> <span class="status completed">Confirmed</span></p>
                    <div class="booking-actions">
                        <button class="btn-view"><i class="bx bx-show"></i> View</button>
                        <button class="btn-edit"><i class="bx bx-x"></i> Cancel</button>
                    </div>
                </div>
            </div>
        </main>
        <!-- MAIN -->
    </section>
    <!-- CONTENT -->
</body>
</html>